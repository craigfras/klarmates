# Environment template — copy to `.env.local` and fill in real values.
# `.env.local` is git-ignored; this template is committed.

# Postgres connection (managed Neon instance). Get these from the Neon
# dashboard → your project → "Connection string". `sslmode=require` is required.

# Used by the running app (and the seed). The pooled "-pooler" host is fine here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require"

# OPTIONAL — used only by Prisma migrations (prisma.config.ts). Set this to the
# DIRECT (unpooled) host to avoid pooled-connection migrate failures. If you
# only set DATABASE_URL and it's already the direct host, migrations work too.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Service backend selection. Default (unset / any value but "false") = in-memory
# mock. Set to "false" to use the Postgres-backed services (requires DATABASE_URL).
USE_MOCK=false

# Google SSO (Auth.js v5). Create an OAuth 2.0 Client in Google Cloud Console.
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="a-long-random-string"
# Base URL of the app (e.g. http://localhost:3000 in dev).
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini API (slice 11). Used server-side only to generate the weekly
# icebreaker questions and the per-answer distractors. Create a key in Google AI
# Studio at https://aistudio.google.com/apikey.
# If unset or invalid, generation falls back to canned stubs (the game still works,
# with a logged warning). NEVER expose this to the client.
GEMINI_API_KEY="..."

# Slack Bot User OAuth token (slice 12), starting with `xoxb-`. Used server-side
# only to DM players their weekly notifications (new week, guessing unlocked,
# end-of-week reminder, results). If unset, all Slack notifications no-op safely
# (logged with a warning; the game still works). NEVER exposed to the client.
SLACK_BOT_TOKEN="xoxb-..."

# Scheduled-jobs secret (slice 13): a long random string. Vercel Cron sends it
# as `Authorization: Bearer <CRON_SECRET>` when hitting the /api/cron/* routes;
# those routes reject any request without the exact bearer (and reject ALL
# requests when this is unset). Also used to invoke the jobs manually.
CRON_SECRET="a-long-random-string"
